# -----------------------------------------------------------------------
# AI-Powered Sign Language Detection System
# Environment Variable Template - Version 0
# -----------------------------------------------------------------------
# Copy this file to ".env" and update values as needed:
#   cp .env.example .env
# -----------------------------------------------------------------------

# Flask entry point file
FLASK_APP=app.py

# Environment mode: development | production
FLASK_ENV=development

# Port on which the Flask AI service will run
PORT=5000

# Path to the trained AI model file (used in future versions)
MODEL_PATH=models/model.h5
